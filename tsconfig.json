{
  "compilerOptions": {
    "skipLibCheck": true, //跳过库类型检查
    "allowSyntheticDefaultImports": true, //允许合成默认导入
    "noUncheckedIndexedAccess": true, // Extra safety for array and object lookups, but may have false positives.
    "noImplicitAny": false, //允许隐式any
    "baseUrl": "./",
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"]
    }, // Path mapping for cleaner imports.
    "module": "preserve", // Most tools use transpilation instead of Node.js's native type-stripping. Bundler mode provides a smoother developer experience.
    "moduleResolution": "bundler",
    
    "noEmit": true, // Disable emitting output during `vue-tsc --build`, which is used for type-checking only.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo" // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking. Specified here to keep it out of the root directory.
  },
  "include": [
    
    "env.d.ts",
    "src/**/*",
    "src/**/*.md",
    "src/**/*.vue",
    "public/models",
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "playwright.config.*",
    "eslint.config.*"
  ],
  "exclude": ["node_modules", "src/**/__tests__/*"],
  
}
